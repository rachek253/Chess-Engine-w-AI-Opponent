# controller/controller.py
# ==============================

class GameController:
    def __init__(self, game_manager, bot=None):
        self.game = game_manager
        self.bot = bot

    def player_move(self, start, end):
        success = self.game.move(start, end)

        if success and self.bot:
            bot_move = self.bot.choose_move(self.game.get_board(), 'black')
            if bot_move:
                self.game.move(*bot_move)

        return success

    def get_board(self):
        return self.game.get_board()


