import pygame


class PygameGUI:
    def __init__(self, controller):
        pygame.init()
        self.controller = controller
        self.size = 600
        self.rows = 8
        self.square_size = self.size // self.rows
        self.screen = pygame.display.set_mode((self.size, self.size))
        pygame.display.set_caption("Chess")
        self.selected = None

    def draw_board(self):
        colors = [(240,217,181), (181,136,99)]
        board = self.controller.get_board()

        for r in range(8):
            for c in range(8):
                color = colors[(r+c)%2]
                pygame.draw.rect(self.screen, color,
                                 (c*self.square_size, r*self.square_size,
                                  self.square_size, self.square_size))

                piece = board[r][c]
                if piece != '':
                    font = pygame.font.SysFont(None, 36)
                    text = font.render(piece, True, (0,0,0))
                    self.screen.blit(text, (c*self.square_size+20, r*self.square_size+20))

    def get_square_from_mouse(self, pos):
        x, y = pos
        row = y // self.square_size
        col = x // self.square_size
        return (row, col)

    def start(self):
        running = True

        while running:
            self.draw_board()
            pygame.display.flip()

            for event in pygame.event.get():
                if event.type == pygame.QUIT:
                    running = False

                elif event.type == pygame.MOUSEBUTTONDOWN:
                    pos = pygame.mouse.get_pos()
                    square = self.get_square_from_mouse(pos)

                    if self.selected is None:
                        self.selected = square
                    else:
                        self.controller.player_move(self.selected, square)
                        self.selected = None

        pygame.quit()


