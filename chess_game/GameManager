from typing import List, Tuple

Position = Tuple[int, int]
Move = Tuple[Position, Position]


class GameManager:
    def __init__(self):
        self.board = self._create_board()
        self.current_turn = 'white'
        self.game_over = False

    def new_game(self):
        self.board = self._create_board()
        self.current_turn = 'white'
        self.game_over = False

    def _create_board(self):
        return [
            ['r','n','b','q','k','b','n','r'],
            ['p','p','p','p','p','p','p','p'],
            ['','','','','','','',''],
            ['','','','','','','',''],
            ['','','','','','','',''],
            ['','','','','','','',''],
            ['P','P','P','P','P','P','P','P'],
            ['R','N','B','Q','K','B','N','R']
        ]

    def resign(self):
        self.game_over = True
        return f"{self.current_turn} resigns"

    def get_legal_moves(self, pos: Position) -> List[Position]:
        if self.game_over:
            return []

        r, c = pos
        piece = self.board[r][c]
        if piece == '':
            return []

        moves = []
        directions = [(-1,0),(1,0),(0,-1),(0,1)]

        for dr, dc in directions:
            nr, nc = r + dr, c + dc
            if 0 <= nr < 8 and 0 <= nc < 8:
                moves.append((nr, nc))

        return moves

    def move(self, start: Position, end: Position) -> bool:
        if self.game_over:
            return False

        legal_moves = self.get_legal_moves(start)
        if end not in legal_moves:
            return False

        r1, c1 = start
        r2, c2 = end

        self.board[r2][c2] = self.board[r1][c1]
        self.board[r1][c1] = ''

        self._switch_turn()
        return True

    def get_board(self):
        return [row[:] for row in self.board]

    def _switch_turn(self):
        self.current_turn = 'black' if self.current_turn == 'white' else 'white'


